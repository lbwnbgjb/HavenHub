<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- 主标题 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@color/yellow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="仪表盘"
        app:titleTextColor="@color/black" />
    <!-- 可滚动内容区域 -->



    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingTop="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- 网络速度卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/network_speed_card"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/yellow">

                    <TextView
                        android:id="@+id/textView6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="16dp"
                        android:text="实时电费"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/textView5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="今天已用30千瓦时"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/textView6"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="@+id/textView6"
                        app:layout_constraintTop_toBottomOf="@+id/textView6"
                        app:layout_constraintVertical_bias="0.508" />

                    <TextView
                        android:id="@+id/textView7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剩余电量50千瓦时"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.773"
                        app:layout_constraintStart_toEndOf="@+id/textView5"
                        app:layout_constraintTop_toBottomOf="@+id/textView6"
                        app:layout_constraintVertical_bias="0.524" />


                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- 出站模式卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/mode_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/network_speed_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/yellow"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/mode_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="出站模式"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/mode_title"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="16dp">

                        <RadioButton
                            android:id="@+id/btn_rule"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="规则"
                            android:checked="true"
                            android:buttonTint="@color/my_light_primary"
                            android:textColor="#000000"/>

                        <RadioButton
                            android:id="@+id/btn_direct"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="直连"
                            android:buttonTint="@color/my_light_primary"
                            android:textColor="#000000"/>

                        <RadioButton
                            android:id="@+id/btn_global"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="全局"
                            android:buttonTint="@color/my_light_primary"
                            android:textColor="#000000"/>
                    </RadioGroup>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- 公网IP卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/ip_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/mode_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/yellow"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/ip_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="公网IP"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tv_public_ip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="223.104.18.223"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        app:layout_constraintTop_toBottomOf="@id/ip_title"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- DNS卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/dns_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/ip_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/yellow"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/dns_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DNS"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tv_dns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="120.210.251.206"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        app:layout_constraintTop_toBottomOf="@id/dns_title"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- 双列信息卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/stats_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/dns_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/yellow"
                    android:padding="16dp">

                    <!-- 活跃连接 -->
                    <TextView
                        android:id="@+id/connections_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="今日用水"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guideline"/>

                    <TextView
                        android:id="@+id/tv_active_connections"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="0T"
                        android:textSize="24sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        app:layout_constraintTop_toBottomOf="@id/connections_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guideline"
                        android:layout_marginTop="8dp"/>

                    <!-- 流量使用 -->
                    <TextView
                        android:id="@+id/usage_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="流量使用"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="@id/guideline"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <TextView
                        android:id="@+id/tv_data_usage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="0 B"
                        android:textSize="24sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        app:layout_constraintTop_toBottomOf="@id/usage_title"
                        app:layout_constraintStart_toStartOf="@id/guideline"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="8dp"/>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#E0E0E0"
                        app:layout_constraintTop_toTopOf="@id/tv_active_connections"
                        app:layout_constraintBottom_toBottomOf="@id/tv_active_connections"
                        app:layout_constraintStart_toStartOf="@id/guideline"
                        app:layout_constraintEnd_toEndOf="@id/guideline"/>

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guideline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_begin="180dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>